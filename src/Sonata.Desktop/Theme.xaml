<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackgroundBrush"
                     Color="#211F25" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush"
                     Color="#302E36" />
    <SolidColorBrush x:Key="PanelBackgroundBrush"
                     Color="#29272E" />
    <SolidColorBrush x:Key="DetailBackgroundBrush"
                     Color="#34313A" />
    <SolidColorBrush x:Key="UserMessageBrush"
                     Color="#3B4652" />
    <SolidColorBrush x:Key="AssistantMessageBrush"
                     Color="#3A373F" />
    <SolidColorBrush x:Key="WarningBackgroundBrush"
                     Color="#4A3428" />
    <SolidColorBrush x:Key="PrimaryTextBrush"
                     Color="#F5F2F7" />
    <SolidColorBrush x:Key="SecondaryTextBrush"
                     Color="#AAA4B5" />
    <SolidColorBrush x:Key="MutedTextBrush"
                     Color="#817B8B" />

    <Style x:Key="EmptyStateTextStyle"
           TargetType="TextBlock">
        <Setter Property="Foreground"
                Value="{DynamicResource MutedTextBrush}" />
        <Setter Property="TextAlignment"
                Value="Center" />
        <Setter Property="TextWrapping"
                Value="Wrap" />
        <Setter Property="Margin"
                Value="16" />
    </Style>
</ResourceDictionary>